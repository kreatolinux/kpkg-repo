name: "kbd"
version: "2.10.0"
release: "1"
description: "Linux keyboard tools"
sources:
 - "https://git.kernel.org/pub/scm/linux/kernel/git/legion/kbd.git/snapshot/kbd-${version}.tar.gz"
sha256sum:
 - "96f8b60f9136e9e0b9261b9e63b8b4b456a2f817901e90349453387a5aa1d41c"
build_depends:
 - "autoconf"
 - "automake"
 - "gettext"
 - "libtool"
 - "gmake"

build {
 exec "autoreconf -v -f -i"
 macro build --disable-vlock --bindir=/usr/bin
}

package {
 macro package
}


