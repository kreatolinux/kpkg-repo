name: "xmlto"
version: "0.0.29"
release: "1"
description: "Convert xml to many other formats"
sources:
 - "https://releases.pagure.org/xmlto/xmlto-${version}.tar.gz"
sha256sum:
 - "40504db68718385a4eaa9154a28f59e51e59d006d1aa14f5bc9d6fded1d6017a"
depends:
 - "libxslt"
 - "docbook-xml"
 - "docbook-xsl"
 - "links"
build_depends:
 - "gmake"

build {
 env CFLAGS="$CFLAGS -Wno-implicit-int"
 env LINKS="/usr/bin/links"
 macro build
}

package {
 macro package
}


