name: "libffi"
version: "3.7.0"
release: "1"
description: "A portable foreign-function interface library."
sources:
 - "https://github.com/libffi/libffi/releases/download/v${version}/libffi-${version}.tar.gz"
sha256sum:
 - "2255c5a638dfb51bf67c20a12a7bb70d17feb1e9eababac05f5573146f586436"
build_depends:
 - "gmake"

build {
 env CFLAGS="$CFLAGS -Wno-implicit-function-declaration"
 macro build 
}

package {
 macro package
 exec "rm -rf \"$ROOT/usr/share/info/dir\""
}


