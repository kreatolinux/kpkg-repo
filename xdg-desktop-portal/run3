name: "xdg-desktop-portal"
version: "1.20.4"
release: "1"
description: "A portal frontend service for Flatpak and possibly other desktop containment frameworks"
sources:
 - "https://github.com/flatpak/xdg-desktop-portal/releases/download/${version}/xdg-desktop-portal-${version}.tar.xz"
sha256sum:
 - "9528eb3b060b88ac82f294fbdc6af5f4d3adfa42575f2cd816cab3d3e0a7a68c"
depends:
 - "glib"
 - "flatpak"
 - "bubblewrap"
 - "geoclue"
 - "gdk-pixbuf"
 - "fuse"
 - "pipewire"
 - "json-glib"
build_depends:
 - "meson"
opt_depends:
 - "xdg-desktop-portal-gtk: GTK backend"
 - "xdg-desktop-portal-gnome: GNOME backend"
 - "xdg-desktop-portal-wlr: wlroots backend"

build {
 macro build -Ddocbook-docs=disabled
}

package {
 macro package
}


