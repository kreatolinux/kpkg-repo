name: "wl-clipboard"
version: "2.3.0"
release: "1"
description: "Command-line copy/paste utilities for Wayland"
sources:
  - "https://github.com/bugaevc/wl-clipboard/archive/refs/tags/v$version.tar.gz"
sha256sum:
  - "b4dc560973f0cd74e02f817ffa2fd44ba645a4f1ea94b7b9614dacc9f895f402"
depends:
  - "wayland"
  - "wayland-protocols"
build_depends:
  - "meson"

build {
  exec "meson --prefix=/usr build/"
  exec "ninja -C build/"
}

package {
  exec "DESTDIR=$ROOT ninja -C build/ install"
}

