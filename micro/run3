name: "micro"
version: "2.0.15"
release: "1"
description: "micro is a terminal-based text editor that aims to be easy to use and intuitive"
sources:
  - "https://github.com/zyedidia/micro/archive/refs/tags/v$version.tar.gz"
sha256sum:
  - "612c775321c268c8f9e1767505ff378bca9b9ab66f5c41b69ecb2464ecf15084"
build_depends:
  - "go"
  - "gmake"

build {
  exec "make build"
}

package {
  exec "env install -vD micro \"$ROOT/usr/bin/micro\""
}

