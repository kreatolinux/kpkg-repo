name: python
version: 3.14.5
release: 5
description: "General-Purpose Programming language"
sources:
  - "https://www.python.org/ftp/python/${version}/Python-${version}.tar.xz"
  - "https://github.com/python/cpython/commit/3364e7e62fa24d0e19133fb0f90b1c24ef1110c5.patch"
  - "https://raw.githubusercontent.com/python/cpython/7cdbb779a82d600d6cf01508214c2bbde111e1f6/Modules/_ssl_data_40.h"
sha256sum:
  - "7e32597b99e5d9a39abed35de4693fa169df3e5850d4c334337ffd6a19a36db6"
  - "15d2886dbca59ceec2f2ec8f7eea3d37fa899fad58d8c2228e9628ea3a318487"
  - "fb6a22bb6a03931a887b4947c6687af6a109d0e76645a87349664cae7aa5845e"

prepare {
  exec "patch -p1 < ../3364e7e62fa24d0e19133fb0f90b1c24ef1110c5.patch"
  exec "cp ../_ssl_data_40.h Modules/_ssl_data_40.h"
  exec "perl -0pi -e 's/#if \\(OPENSSL_VERSION_NUMBER >= 0x30401000L\\)\n#include \\x22_ssl_data_35.h\\x22/#if (OPENSSL_VERSION_NUMBER >= 0x40000000L)\n#  include \\x22_ssl_data_40.h\\x22\n#elif (OPENSSL_VERSION_NUMBER >= 0x30401000L)\n#  include \\x22_ssl_data_35.h\\x22/' Modules/_ssl.c"
  exec "grep -q '_ssl_data_40.h' Modules/_ssl.c"
}

build {
  macro build --enable-shared --with-system-expat
}

package {
  macro package
  exec "ln -s python3 $ROOT/usr/bin/python"
  exec "find $ROOT -type f -name '*.pyc' -delete"
  exec "find $ROOT -type d -name '__pycache__' | xargs rm -rf"
}
