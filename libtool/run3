name: "libtool"
version: "2.6.2"
release: "1"
description: "The GNU Portable Library Tool"
sources:
  - "https://ftp.gnu.org/gnu/libtool/libtool-$version.tar.gz"
sha256sum:
  - "24adb3aa9ae035c70faba344af57d73215eb89281045af6c7ccd307751f8b0bf"
depends:
  - "m4"
build_depends:
  - "gmake"

build {
  macro build --prefix=/usr
  exec "make"
}

package {
  exec "make DESTDIR=$ROOT install"
  exec "rm -rf \"$ROOT\"/usr/share/info/dir"
}

