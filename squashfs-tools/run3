name: "squashfs-tools"
version: "4.7.5"
release: "1"
description: "Tools for managing SquashFS"
sources:
  - "https://github.com/plougher/squashfs-tools/archive/refs/tags/$version.tar.gz"
sha256sum:
  - "547b7b7f4d2e44bf91b6fc554664850c69563701deab9fd9cd7e21f694c88ea6"
build_depends:
  - "gmake"

build {
  cd "squashfs-tools"
  exec "make INSTALL_MANPAGES_DIR=\"\""
}

package {
  exec "rm -f ../generate-manpages/install-manpages.sh"
  exec "touch ../generate-manpages/install-manpages.sh"
  exec "chmod +x ../generate-manpages/install-manpages.sh"
  exec "make INSTALL_MANPAGES_DIR=\"\" INSTALL_PREFIX=$ROOT/usr DESTDIR=$ROOT install"
}

