name: "openssh"
version: "9.9p1"
release: "3"
description: "ssh tools"
sources:
 - "https://ftp.openbsd.org/pub/OpenBSD/OpenSSH/portable/openssh-${version}.tar.gz"
 - "openssl4-version-check.patch"
sha256sum:
 - "b343fbcdbff87f15b1986e6e15d6d4fc9a7d36066be6b7fb507087ba8f966c02"
 - "22b6a645d7c8e6493c5496a1e5bf0afd8c518edd8e90e3bd53c3ff6360e02df6"
depends:
 - "shadow"
 - "zlib"
build_depends:
 - "gmake"

prepare {
 exec "patch -p1 < ../openssl4-version-check.patch"
}

build {
 macro build --without-zlib-version-check
}

package {
 macro package
}
