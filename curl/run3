name: "curl"
version: "8.20.0"
release: "1"
description: "command line tool and library for transferring data with URLs"
sources:
 - "https://curl.haxx.se/download/curl-${version}.tar.xz"
sha256sum:
 - "63fe2dc148ba0ceae89922ef838f7e5c946272c2e78b7c59fab4b79d3ce2b896"
depends:
 - "nghttp2"
 - "zlib"
 - "nghttp2"
build_depends:
 - "gmake"

build {
# Taken from Kiss Linux repo, License here https://github.com/kisslinux/repo/blob/master/LICENSE
 macro build --configure --disable-manual --disable-ldap --disable-ares --without-librtmp --without-libpsl --without-libidn2 --without-brotli --without-zstd --with-openssl --with-nghttp2 --with-ca-path=/etc/ssl/certs

}

package {
 macro package --configure
}


