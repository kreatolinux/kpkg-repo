name: "findutils"
version: "4.11.0"
release: "1"
description: "GNU findutils"
sources:
  - "https://ftp.gnu.org/gnu/findutils/findutils-$version.tar.xz"
sha256sum:
  - "bfd19cb06cc71f3352d567e90284d8cdac02ac89774bbeadf0b533b0c11432fd"
build_depends:
  - "gmake"

build {
  exec "mkdir -v build"
  cd "build"
  macro build --configure=.. --disable-nls --enable-shared --disable-werror --enable-64-bit-bfd
  exec "make"
}

package {
  exec "make DESTDIR=$ROOT install -j1"
}

