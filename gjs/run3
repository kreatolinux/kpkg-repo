name: "gjs"
version: "1.88.0"
release: "1"
description: "Javascript bindings for GNOME"
sources:
 - "https://gitlab.gnome.org/GNOME/gjs/-/archive/${version}/gjs-${version}.tar.gz"
sha256sum:
 - "2235ba7858a9f29b6a5941d99511c79620fb9033a4077d7ac678a22a9dac8eb8"
depends:
