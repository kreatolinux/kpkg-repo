name: "freetype"
version: "2.14.3"
release: "2"
description: "FriBidi is an implementation of Unicode Bidirectional Algorithm"
sources:
  - "https://download-mirror.savannah.gnu.org/releases/freetype/freetype-$version.tar.gz"
sha256sum:
  - "e61b31ab26358b946e767ed7eb7f4bb2e507da1cfefeb7a8861ace7fd5c899a1"
depends:
  - "libpng"
build_depends:
  - "ninja"
  - "meson"

build {
  exec "meson  --prefix=/usr  -Dharfbuzz=disabled  -Dbzip2=disabled  . output"
  exec "ninja -C output"
}

package {
  exec "DESTDIR=$ROOT ninja -C output install"
}

