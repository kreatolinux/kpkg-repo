name: "sudo"
version: "1_9_15p4"
release: "3"
description: "Utility to execute a command as another user"
sources:
  - "https://github.com/sudo-project/sudo/archive/refs/tags/SUDO_$version.tar.gz"
  - "483.patch"
sha256sum:
  - "bd3b5348209e3cb2941e4e83f6bb3fd4da065c943a2bb6620a3778264ec0631a"
  - "d3146b50637be83c3aafa2f378dc2c4fab94fff41d894a39a77fc95c0523a73d"
depends:
  - "linux-pam"
  - "shadow"
build_depends:
  - "gmake"

prepare {
  exec "patch -p1 < ../483.patch"
}

build {
  env CFLAGS="$CFLAGS -Wno-error=incompatible-pointer-types"
  macro build --configure
}

package {
  macro package --configure
  # From BLFS
  exec "mkdir -p $ROOT/etc/pam.d"
  write "$ROOT/etc/pam.d/sudo" """
# Begin /etc/pam.d/sudo

# include the default auth settings
auth      include     system-auth

# include the default account settings
account   include     system-account

# Set default environment variables for the service user
session   required    pam_env.so

# include system session defaults
session   include     system-session

# End /etc/pam.d/sudo
"""
  exec "chmod 644 $ROOT/etc/pam.d/sudo"
}
